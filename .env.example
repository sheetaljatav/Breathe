# Copy to .env and fill in. Never commit .env.
# All values are required unless marked OPTIONAL.

# Django
DJANGO_SETTINGS_MODULE=breathe.settings.dev
DJANGO_SECRET_KEY=replace-me-with-a-50-char-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Postgres
# Local dev: postgres://breathe:breathe@localhost:5432/breathe
# Render: provided automatically as DATABASE_URL
DATABASE_URL=postgres://breathe:breathe@localhost:5432/breathe

# Postgres role with restricted privileges on audit_log (no UPDATE/DELETE).
# In production, create this as a separate role and use it as APP_DB_USER below.
# In dev, leaving this unset means Django uses the DATABASE_URL user directly
# and the audit-immutability test must run under a privilege-dropped session.
APP_DB_USER=breathe_app
APP_DB_PASSWORD=breathe_app

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Sentry (OPTIONAL — leave empty in dev)
SENTRY_DSN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
